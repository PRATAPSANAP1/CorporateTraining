# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration
MONGODB_URI=mongodb://localhost:27017/mce-placement-portal

# JWT Security (Required - no default)
JWT_SECRET=your_jwt_secret_key_here_must_be_long_and_secure
JWT_EXPIRE=7d

# Third-party Integrations
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
JUDGE0_API_KEY=
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com

# Email configuration (Optional/Resend)
RESEND_API_KEY=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Frontend configuration
CLIENT_URL=https://corporate-training-olive.vercel.app
